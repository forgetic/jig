# jig-record secrets — copy to `record.env` (gitignored) and fill in.
#
# The recorder is a transparent passthrough proxy: it does NOT authenticate to
# the upstream itself. The official client you drive through it carries the
# credential, so this file holds the env that client reads. Source it, point the
# client's base URL at the proxy, and the auth header rides through on the wire
# (and is redacted in the captured fixture).
#
#   source crates/jig-record/record.env
#   jig record --client openai-sdk --scenario single-text &   # prints base_url
#   OPENAI_BASE_URL="$base_url" OPENAI_API_KEY="$OPENAI_API_KEY" <run official client>

# OpenAI
OPENAI_API_KEY=sk-replace-me

# DeepSeek (OpenAI-compatible; drive with --upstream-host api.deepseek.com)
DEEPSEEK_API_KEY=sk-replace-me
